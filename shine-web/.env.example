# ============================================================
# Firebase Client (NEXT_PUBLIC_* se exponen al navegador — es por diseño)
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo:  cp .env.example .env.local
#   2. Llena los valores con tus credenciales de Firebase
#   3. Reinicia el servidor: Ctrl+C → bun dev
#
# Donde encontrar las credenciales:
#   Firebase Console → Project Settings → General → Your apps → Web app
#
# IMPORTANTE: .env.local NO está en git. Cada Codespace nuevo necesita
# recrear este archivo. Puedes usar: bash scripts/setup-env.sh
# ============================================================

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================
# Stripe (pagos)
# ============================================================
# Donde encontrar:
#   Stripe Dashboard → Developers → API keys
#   Publishable key = pk_test_... o pk_live_...
#   Secret key = sk_test_... o sk_live_...
#
# Webhook secret:
#   Stripe Dashboard → Developers → Webhooks → [tu endpoint] → Signing secret
#   (whsec_...)
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================
# Resend (envío de emails — recibos de pago)
# ============================================================
# Donde encontrar:
#   1. Crea cuenta en https://resend.com
#   2. Dashboard → API Keys → Create API Key
#   3. Dashboard → Domains → Agrega tu dominio o usa onboarding@resend.dev
#
# RESEND_FROM_EMAIL debe ser un email verificado en tu dominio de Resend.
# Ejemplo: "Shine <noreply@tudominio.com>"
# En desarrollo puedes usar: "Shine <onboarding@resend.dev>"
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=Shine <onboarding@resend.dev>

# ============================================================
# Firebase Admin SDK (solo servidor — para generar links de reset)
# ============================================================
# Donde encontrar:
#   Firebase Console → Project Settings → Service Accounts
#   1. Haz clic en "Generate New Private Key"
#   2. Se descarga un JSON — copia "client_email" y "private_key"
#   3. La private_key debe estar entre comillas dobles y los \n literales
#      se escriben como \\n en el .env.local
#
# IMPORTANTE: NUNCA hagas commit con valores reales
# ============================================================
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Prisma / SQLite (actualmente sin uso en la app)
# DATABASE_URL=file:./db/custom.db