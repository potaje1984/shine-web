rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // Pedidos — flujo "Presupuesto Final"
    //
    // Estados:
    //   esperando_peso  → creado por cliente, esperando que admin pese
    //   listo_para_pago → admin fijó finalPrice, listo para cobrar
    //   pagado          → Stripe confirmó el pago (vía webhook)
    //   completado      → servicio entregado
    //   cancelado       → cancelado
    //
    // REGLAS:
    //   • CREATE (cliente): solo puede enviar datos del pedido, NO status
    //     ni finalPrice. El status lo fuerza el backend a 'esperando_peso'.
    //   • UPDATE/DELETE (admin): solo usuarios autenticados.
    //   • El cliente NO puede modificar status ni finalPrice nunca.
    // ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // CREATE — cliente rellenando el formulario
      allow create: if true
        // Bloquear que el cliente intente fijar status o finalPrice
        && !(request.resource.data.status != null)
        && !(request.resource.data.finalPrice != null)
        && !(request.resource.data.paymentStatus != null)
        && !(request.resource.data.paymentLink != null);

      // UPDATE/DELETE — solo admin autenticado
      // El cliente NO puede actualizar su propio pedido
      allow update, delete: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Configuración de pasarela de pago — solo admin
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // ──────────────────────────────────────────────────────────────
    // users/{uid} — perfil de cliente con Stripe Customer + tarjetas
    //
    // Seguridad:
    //   • Cada usuario solo puede LEER su propio documento
    //   • La ESCRITURA la hacen exclusivamente las Cloud Functions
    //     (admin SDK salta las reglas) → el cliente no puede manipular
    //     su stripeCustomerId, paymentMethods, defaultPaymentMethodId.
    //   • El admin puede leer cualquier usuario (para ver tarjetas y cobrar)
    // ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.token.admin == true);
      // Solo Cloud Functions (admin SDK) escribe. Cliente nunca.
      allow write: if false;
    }

    // Bloquear todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
