rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pedidos:
    //   • create  → público (cualquiera puede pedir desde la web)
    //   • read/update/delete → solo usuarios autenticados (panel /admin)
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Configuración de pasarela de pago:
    //   • Solo el admin puede leer/escribir la publishable key.
    //   • La SECRET key NUNCA se guarda aquí: va en Cloud Functions env vars.
    //   • En el frontend solo se persisten campos públicos.
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // Bloquear todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
