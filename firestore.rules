# Reglas de Firestore recomendadas para Shine
# Copia este contenido en: Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pedidos:
    //   • create  → público (cualquiera puede pedir desde la web)
    //   • read/update/delete → solo usuarios autenticados (panel /admin)
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Bloquear todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
