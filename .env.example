# ──────────────────────────────────────────────────────────────────────────
# Configuración de Firebase — copia este archivo a `.env` y rellena tus valores.
# Encuéntralos en: https://console.firebase.google.com/ → tu proyecto →
# Project settings → General → "Your apps" → Web app → SDK setup and configuration
# ──────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=shine-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=shine-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=shine-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
